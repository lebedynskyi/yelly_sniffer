# Copy this file to .env and fill in real values. .env is gitignored.

# WordPress (XML-RPC)
WP_RPC_URL=https://example.com/xmlrpc.php
WP_RPC_USER=user_name
WP_RPC_PASSWORD=change-me

# Facebook (Graph API)
FB_PAGE_ID=your-page-id
FB_PAGE_ACCESS_TOKEN=change-me

# AI content fixer
# AI_PROVIDER selects the backend: openai | gemini | ollama
# Only the API key/URL matching AI_PROVIDER is required; *_MODEL vars are optional
# (each has a built-in default) and can be pre-staged for all three providers.
AI_PROVIDER=gemini
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.0-flash
OLLAMA_MODEL=llama3
GEMINI_API_KEY=change-me
OPENAI_API_KEY=change-me
OLLAMA_BASE_URL=http://localhost:11434
# Optional: seconds to wait for `ollama serve` to become ready when auto-started (default 15)
OLLAMA_STARTUP_TIMEOUT=15
